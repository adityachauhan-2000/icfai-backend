# ==========================================
# Environment Variables & Secrets (CRITICAL)
# ==========================================
# Ignore all .env files containing secrets and API keys
.env
.env.*
!.env.example
!.env.template

# ==========================================
# Python & Bytecode
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
wheels/

# ==========================================
# Virtual Environments
# ==========================================
venv/
.venv/
env/
.env_venv/
ENV/
env.bak/
venv.bak/

# ==========================================
# FastAPI / SQLAlchemy / Database Artifacts
# ==========================================
# Local SQLite databases (often used during local dev/testing)
*.db
*.sqlite
*.sqlite3

# Local file upload directories (if testing uploads locally)
/uploads/
/media/
/static/cache/

# ==========================================
# Testing, Coverage & Linters
# ==========================================
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/
.ruff_cache/
.mypy_cache/
.pyre/
.pytype/
pip-log.txt
pip-delete-this-directory.txt

# ==========================================
# Application Logs & Process IDs
# ==========================================
*.log
logs/
gunicorn.pid
celerybeat-schedule
celerybeat.pid

# ==========================================
# IDEs & OS-Specific Files
# ==========================================
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.swp
*.swo
*~
.DS_Store
.DS_Store?
._*
Thumbs.db